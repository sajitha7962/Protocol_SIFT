# Protocol SIFT — Environment Configuration
# Copy this to .env and fill in your values

# App
DEBUG=false
SECRET_KEY=change-this-to-a-strong-random-string

# PostgreSQL (optional — Redis is used as primary store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sift
POSTGRES_USER=sift
POSTGRES_PASSWORD=sift_password

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sift-graph

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# Storage
EVIDENCE_STORAGE_PATH=./evidence_store
MAX_UPLOAD_SIZE_MB=2048

# Confidence Thresholds
CONFIDENCE_REINVESTIGATE_THRESHOLD=0.60
CONFIDENCE_CONFIRMED_THRESHOLD=0.85

# CORS (comma-separated origins)
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
